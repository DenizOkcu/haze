{
  "name": "@denizokcu/haze",
  "version": "0.6.0",
  "description": "A pragmatic agentic CLI for building apps from the terminal.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DenizOkcu/haze.git"
  },
  "bugs": {
    "url": "https://github.com/DenizOkcu/haze/issues"
  },
  "homepage": "https://github.com/DenizOkcu/haze#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "haze": "bin/haze.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "examples"
  ],
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist', {recursive: true, force: true})\"",
    "build": "npm run clean && tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "context:report": "node --import tsx src/cli/contextReport.ts",
    "haze": "tsx src/cli/index.ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.52",
    "@ai-sdk/openai": "3.0.73",
    "@inquirer/prompts": "8.5.2",
    "@vscode/ripgrep": "1.18.0",
    "ai": "6.0.208",
    "cli-highlight": "2.1.11",
    "commander": "15.0.0",
    "defuddle": "^0.19.0",
    "fs-extra": "11.3.5",
    "ink": "7.1.0",
    "ink-spinner": "5.0.0",
    "linkedom": "^0.18.12",
    "marked": "18.0.5",
    "react": "19.2.7",
    "strip-ansi": "7.2.0",
    "turndown": "^7.2.4",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fs-extra": "11.0.4",
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "eslint": "^10.5.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
